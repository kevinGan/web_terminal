# --- Dependencies ----------------------------------------------------------
node_modules/
.pnpm-store/

# --- Build outputs ---------------------------------------------------------
dist/
dist-ssr/
build/Release/
build/Debug/
# vite-plugin-pwa dev-mode service worker output (any depth)
dev-dist
# Generated frontend dist by vite (covered by `dist/` above) — kept explicit
# so it's obvious why packages/web/dist is ignored:
packages/*/dist/

# --- Logs & caches ---------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.eslintcache
.parcel-cache
.turbo
.cache/
*.tsbuildinfo
.vite/

# --- Env / secrets ---------------------------------------------------------
.env
.env.*
!.env.example

# --- Editor / IDE ----------------------------------------------------------
.idea/
.vscode/*
# Keep shared/editor recommendations checked in.
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json

# --- OS files --------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Desktop.ini
ehthumbs.db
Icon?

# --- Test / e2e artifacts --------------------------------------------------
coverage/
.playwright-mcp/
playwright-report/
test-results/

